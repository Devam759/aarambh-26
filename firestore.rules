rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions for role checks
    function getRole(uid) {
      return get(/databases/$(database)/documents/roles/$(uid)).data.role;
    }
    
    function isAdmin() {
      return request.auth != null && getRole(request.auth.uid) == 'admin';
    }
    
    function isScanner() {
      return request.auth != null && getRole(request.auth.uid) == 'scanner';
    }
    
    function isVolunteerOrTL() {
      return request.auth != null && (
        getRole(request.auth.uid) == 'volunteer' || 
        getRole(request.auth.uid) == 'team_leader'
      );
    }

    // Roles collection rules
    match /roles/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if isAdmin();
    }

    // Registrations collection
    match /registrations/{id} {
      allow read: if isAdmin() || isScanner();
      allow create: if request.resource.data.paymentId != null && request.resource.data.orderId != null;
      allow update, delete: if isAdmin();
    }

    // Pending Registrations collection
    match /pendingRegistrations/{id} {
      allow read, write: if false; // Only Admin SDK can read/write
    }

    // Volunteers collection
    match /volunteers/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || isVolunteerOrTL();
    }

    // Duty Assignments collection
    match /dutyAssignments/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Notifications/Announcements collections
    match /notifications/{id} {
      allow read, update, delete: if request.auth != null;
      allow create: if request.auth != null && (isAdmin() || isVolunteerOrTL());
    }
    
    match /announcements/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Scan logs collection
    match /scanLogs/{id} {
      allow read: if isAdmin() || isScanner();
      allow write: if isAdmin() || isScanner();
    }

    // Events (public schedule)
    match /events/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Audit logs collection
    match /auditLogs/{id} {
      allow read, update, delete: if isAdmin();
      allow create: if isAdmin();
    }

    // Feedback collection (public anonymous submissions allowed)
    match /feedback/{id} {
      allow create: if true;
      allow read: if isAdmin() || (request.auth != null && getRole(request.auth.uid) == 'feedback');
      allow update, delete: if isAdmin();
    }

    // Settings (e.g. active feedback day settings)
    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Scanner Accounts collection
    match /scannerAccounts/{id} {
      allow read: if request.auth != null && (request.auth.uid == id || isAdmin());
      allow write: if isAdmin();
    }

    // Contact Messages collection (public anonymous submissions allowed)
    match /contact_messages/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
