rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions for role checks
    function getRole(uid) {
      return get(/databases/$(database)/documents/roles/$(uid)).data.role;
    }
    
    function isAdmin() {
      return request.auth != null && getRole(request.auth.uid) == 'admin';
    }
    
    function isScanner() {
      return request.auth != null && getRole(request.auth.uid) == 'scanner';
    }
    
    function isVolunteerOrTL() {
      return request.auth != null && (
        getRole(request.auth.uid) == 'volunteer' || 
        getRole(request.auth.uid) == 'team_leader'
      );
    }
    
    function isWarden() {
      return request.auth != null && getRole(request.auth.uid) == 'warden';
    }


    // Roles collection rules
    match /roles/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if isAdmin();
    }

    // Registrations collection
    match /registrations/{id} {
      allow read: if isAdmin() || isScanner() || (isWarden() && resource.data.hasEntered == true);
      // All registrations are created server-side via Admin SDK which bypasses rules.
      // Disallow direct client creates to prevent fake paid-registration injection.
      allow create: if false;
      allow update: if isAdmin() || isWarden();
      allow delete: if isAdmin();
    }

    // Pending Registrations collection
    match /pendingRegistrations/{id} {
      allow read, write: if false; // Only Admin SDK can read/write
    }

    // Volunteers collection
    // Credentials (passwordHash) must not be publicly readable.
    // Each volunteer can read their own document (Firebase custom token sets uid = volunteers doc id).
    // Team Leaders and Admins can read all volunteers for duty-management.
    match /volunteers/{id} {
      allow read: if request.auth != null && (
        request.auth.uid == id || 
        isAdmin() || 
        getRole(request.auth.uid) == 'team_leader'
      );
      allow write: if isAdmin() || isVolunteerOrTL();
    }

    // Duty Assignments collection
    match /dutyAssignments/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Notifications/Announcements collections
    match /notifications/{id} {
      allow read, update, delete: if request.auth != null;
      allow create: if request.auth != null && (isAdmin() || isVolunteerOrTL());
    }
    
    match /announcements/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Scan logs collection
    match /scanLogs/{id} {
      allow read: if isAdmin() || isScanner() || isWarden();
      allow write: if isAdmin() || isScanner() || isWarden();
    }

    // Events (public schedule)
    match /events/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Audit logs collection
    match /auditLogs/{id} {
      allow read, update, delete: if isAdmin();
      // Only authenticated users can create audit log entries.
      // Server-side routes use the Admin SDK (bypasses rules); client-side uses Firebase Auth sessions.
      allow create: if request.auth != null;
    }

    // Feedback collection (public anonymous submissions allowed)
    match /feedback/{id} {
      allow create: if true;
      allow read: if isAdmin() || (request.auth != null && getRole(request.auth.uid) == 'feedback');
      allow update, delete: if isAdmin();
    }

    // Complaints collection (public submissions allowed)
    match /complaints/{id} {
      allow create: if true;
      allow read: if isAdmin() || (request.auth != null && (getRole(request.auth.uid) == 'feedback' || getRole(request.auth.uid) == 'volunteer' || getRole(request.auth.uid) == 'team_leader'));
      allow update: if isAdmin() || (request.auth != null && getRole(request.auth.uid) == 'feedback');
      allow delete: if isAdmin();
    }

    // Suggestions collection (public submissions allowed)
    match /suggestions/{id} {
      allow create: if true;
      allow read: if isAdmin() || (request.auth != null && (getRole(request.auth.uid) == 'feedback' || getRole(request.auth.uid) == 'volunteer' || getRole(request.auth.uid) == 'team_leader'));
      allow update: if isAdmin() || (request.auth != null && getRole(request.auth.uid) == 'feedback');
      allow delete: if isAdmin();
    }

    // Settings (e.g. active feedback day settings)
    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin() || (request.auth != null && getRole(request.auth.uid) == 'feedback');
    }

    // Scanner Accounts collection
    match /scannerAccounts/{id} {
      allow read: if request.auth != null && (request.auth.uid == id || isAdmin());
      allow write: if isAdmin();
    }

    // Warden Accounts collection
    match /wardenAccounts/{id} {
      allow read: if request.auth != null && (request.auth.uid == id || isAdmin());
      allow write: if isAdmin();
    }

    // Coupons collection
    match /coupons/{id} {
      allow read, write: if isAdmin();
    }

    // Contact Messages collection (public anonymous submissions allowed)
    match /contact_messages/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
